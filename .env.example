# =============================================================================
# U.S. COVID Vaccine Injuries - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control - it contains secrets!
#
# Required variables are marked with [REQUIRED]
# Optional variables will gracefully fall back if not set
# =============================================================================

# =============================================================================
# DATABASE [REQUIRED]
# =============================================================================
# PostgreSQL connection string for Payload CMS data storage.
# Recommended: Supabase PostgreSQL with Session Pooler (for IPv4 compatibility)
#
# Format: postgresql://[user].[project-ref]:[password]@[host]:5432/postgres
# Get from: Supabase Dashboard > Project Settings > Database > Connection string > Session mode
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# =============================================================================
# PAYLOAD CMS [REQUIRED]
# =============================================================================
# Secret key for Payload CMS encryption and CSRF token signing.
# Must be at least 32 characters. Generate with: openssl rand -hex 32
PAYLOAD_SECRET=your-random-secret-at-least-32-characters-long

# =============================================================================
# ADMIN AUTHENTICATION [OPTIONAL]
# =============================================================================
# API key for programmatic access to protected endpoints:
# - GET /api/survey/export (download survey responses as CSV)
# - GET /api/survey/stats (aggregate survey statistics)
#
# Include in requests as header: x-api-key: your-key-here
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# =============================================================================
# RATE LIMITING - UPSTASH REDIS [RECOMMENDED FOR PRODUCTION]
# =============================================================================
# Upstash provides serverless Redis that works across Vercel function instances.
# Without this, rate limiting only works within a single function invocation.
#
# Get free tier at: https://upstash.com
# Create a Redis database, then copy these values from the REST API section.
UPSTASH_REDIS_REST_URL=https://[your-database].upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...your-token

# =============================================================================
# RECAPTCHA V3 [RECOMMENDED]
# =============================================================================
# Protects forms from bot submissions. Works silently without user interaction.
# Score threshold: 0.7 (configurable in lib/recaptcha.ts)
#
# Get keys from: https://www.google.com/recaptcha/admin
# Select "reCAPTCHA v3" when creating a new site.
#
# The SITE_KEY is public (exposed to browser). The SECRET_KEY must stay private.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6L...your-site-key
RECAPTCHA_SECRET_KEY=6L...your-secret-key

# Optional: For reCAPTCHA Enterprise (more features, requires Google Cloud)
# RECAPTCHA_PROJECT_ID=your-gcp-project-id

# =============================================================================
# STRIPE PAYMENTS [OPTIONAL - FOR DONATIONS]
# =============================================================================
# Enables the /donate page for accepting donations.
#
# Get keys from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_/pk_test_) for development.
# Use live keys (sk_live_/pk_live_) for production.
#
# Webhook setup:
# 1. Go to Stripe Dashboard > Developers > Webhooks
# 2. Add endpoint: https://yourdomain.com/api/donation-webhook
# 3. Select event: checkout.session.completed
# 4. Copy signing secret to STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# ERROR TRACKING - SENTRY [OPTIONAL]
# =============================================================================
# Captures and reports errors in production.
# Sampling: 10% of Node.js errors, 5% of Edge runtime errors.
#
# Get DSN from: https://sentry.io > Project Settings > Client Keys (DSN)
# Auth token from: https://sentry.io > Settings > Auth Tokens
NEXT_PUBLIC_SENTRY_DSN=https://[key]@[org].ingest.sentry.io/[project]
SENTRY_AUTH_TOKEN=sntrys_...

# =============================================================================
# DEVELOPMENT/STAGING [OPTIONAL]
# =============================================================================
# Password-protect the entire site (useful for staging environments)
# When set, visitors must enter this password to access any page.
SITE_PASSWORD=

# =============================================================================
# ANALYTICS [AUTO-CONFIGURED]
# =============================================================================
# Vercel Analytics is automatically enabled when deployed to Vercel.
# No configuration needed - it just works!

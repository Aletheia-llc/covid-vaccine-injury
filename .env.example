# Database (Supabase PostgreSQL - use Session Pooler URL for IPv4 compatibility)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Payload CMS Secret (generate a random string, minimum 32 characters)
# Also used for CSRF token signing
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Admin API Key (optional - for authenticated access to /api/survey/export and /api/survey/stats)
# Generate a secure random string: openssl rand -hex 32
ADMIN_API_KEY=

# =============================================================================
# Supabase (for rate limiting - uses same project as DATABASE_URL)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# =============================================================================
# reCAPTCHA v3 Enterprise (optional - skip for development)
# =============================================================================
# Get keys from Google Cloud Console > reCAPTCHA Enterprise
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_PROJECT_ID=

# =============================================================================
# Stripe (for donations - Phase 5)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# Sentry Error Tracking (Phase 4)
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# =============================================================================
# Site Password (optional - for staging/preview protection)
# =============================================================================
SITE_PASSWORD=
